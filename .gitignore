node_modules
dist
.DS_Store
*.local
.env
__pycache__

# Firebase Admin SDK key
*firebase-adminsdk*
scripts/serviceAccountKey.json
.vercel
.env.tmp.*

# Monorepo workspace node_modules + build outputs
apps/*/node_modules/
apps/*/dist/
apps/*/.env
apps/*/.env.*
packages/*/node_modules/
packages/*/dist/
workers/*/node_modules/
workers/*/dist/
workers/*/.dev.vars

# Expo / React Native (apps/mobile)
apps/mobile/.expo/
apps/mobile/android/
apps/mobile/ios/

# Capacitor iOS — generated artifacts (Xcode project source IS tracked)
ios/App/App/public/
ios/App/Pods/
ios/App/Podfile.lock
ios/.DS_Store
ios/App/build/
ios/App/DerivedData/
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/

# Capacitor Android — generated artifacts (Gradle project source IS tracked)
android/app/src/main/assets/public/
android/.gradle/
android/.idea/
android/build/
android/app/build/
android/local.properties
android/captures/
android/app/release/
android/app/debug/
android/*.iml
android/app/*.iml

# Claude Code hook logs
.claude/hooks/.logs/

# Service account keys — never commit
secrets/
*firebase-admin-sa*.json
scripts/migrate/.dump/
.firebase/
