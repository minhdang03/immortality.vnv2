    "AI sẽ tự nhận lĩnh vực khi bạn gõ câu hỏi.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "AI will detect the field as you type your question."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "输入问题时，AI 会自动识别领域。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "質問を入力すると、AIが分野を自動判定します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "질문을 입력하면 AI가 분야를 자동으로 인식해요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'IA détectera le domaine pendant que vous écrivez."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die KI erkennt den Bereich, während du tippst."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La IA detectará el área mientras escribes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ИИ определит область, пока вы печатаете вопрос."
          }
        }
      }
    },
    "Câu hỏi rõ được cộng đồng & chuyên gia trả lời nhanh hơn.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clear questions get faster answers from the community & experts."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "问题越清晰，社区和专家回答得越快。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "明確な質問ほど、コミュニティや専門家から早く回答が届きます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "명확한 질문일수록 커뮤니티와 전문가의 답이 빨라요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les questions claires reçoivent des réponses plus rapides de la communauté et des experts."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Klare Fragen werden von Community & Experten schneller beantwortet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las preguntas claras reciben respuestas más rápidas de la comunidad y los expertos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На ясные вопросы сообщество и эксперты отвечают быстрее."
          }
        }
      }
    },
