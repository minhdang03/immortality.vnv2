      "es" : { "stringUnit" : { "state" : "translated", "value" : "¿Sin cuenta? Regístrate" } },
      "ru" : { "stringUnit" : { "state" : "translated", "value" : "Нет аккаунта? Зарегистрируйтесь" } }
