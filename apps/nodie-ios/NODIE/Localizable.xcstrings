        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지식을 나누고 함께 깊이 파고드는 곳."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Là où l'on partage le savoir et approfondit ensemble."
