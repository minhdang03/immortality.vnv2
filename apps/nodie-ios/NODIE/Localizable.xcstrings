    "Đã có tài khoản? Đăng nhập" : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "Already have an account? Sign in" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "已有账号？登录" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "アカウントをお持ちの方はサインイン" } },
      "ko" : { "stringUnit" : { "state" : "translated", "value" : "이미 계정이 있나요? 로그인" } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Déjà un compte ? Se connecter" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Schon ein Konto? Anmelden" } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "¿Ya tienes cuenta? Inicia sesión" } },
      "ru" : { "stringUnit" : { "state" : "translated", "value" : "Уже есть аккаунт? Войти" } }
    } },
    "Chưa có tài khoản? Đăng ký" : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "No account yet? Sign up" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "还没有账号？注册" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "アカウントがない方は登録" } },
