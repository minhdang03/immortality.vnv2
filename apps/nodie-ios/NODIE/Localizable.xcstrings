    "Tiêu đề cần dài hơn 6 ký tự để mọi người hiểu bạn đang hỏi gì.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Titel sollte länger als 6 Zeichen sein, damit andere verstehen, was du fragst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Make your title longer than 6 characters so others understand your question."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Alarga el título a más de 6 caracteres para que otros entiendan tu pregunta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le titre doit compter plus de 6 caractères pour que les autres comprennent votre question."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タイトルを6文字より長くすると、質問の内容が伝わりやすくなります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "제목을 6자 이상으로 적으면 다른 사람이 질문을 더 잘 이해할 수 있어요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сделайте заголовок длиннее 6 символов, чтобы другим было понятно, о чём вопрос."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "标题超过6个字符，大家才能更好理解你的问题。"
          }
        }
      }
    },
