    "Mật khẩu phải từ 6 ký tự trở lên.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Password must be at least 6 characters."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "密码至少需要 6 个字符。"
          }
        },
        "ja": {
