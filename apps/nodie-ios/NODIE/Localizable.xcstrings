    "＋ Chiếu câu hỏi" : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "＋ Beam a question" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "＋ 提问" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "＋ 質問する" } },
      "ko" : { "stringUnit" : { "state" : "translated", "value" : "＋ 질문하기" } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "＋ Projeter une question" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "＋ Frage stellen" } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "＋ Proyectar una pregunta" } },
      "ru" : { "stringUnit" : { "state" : "translated", "value" : "＋ Задать вопрос" } }
    } },
    "Mỗi câu hỏi là một lần chiếu sáng — hỏi rõ để thu về câu trả lời đúng." : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "Every question is a beam of light — ask clearly to attract the right answers." } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "每个问题都是一次照亮——问得清楚，才能收获对的答案。" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "質問はひとつの光。はっきり尋ねるほど、正しい答えが集まります。" } },
      "ko" : { "stringUnit" : { "state" : "translated", "value" : "질문 하나하나가 빛이 됩니다 — 명확히 물을수록 정확한 답이 모여요." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Chaque question est un rayon de lumière — posez-la clairement pour attirer les bonnes réponses." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Jede Frage ist ein Lichtstrahl — frag klar, um die richtigen Antworten anzuziehen." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Cada pregunta es un rayo de luz: pregunta con claridad para atraer las respuestas correctas." } },
      "ru" : { "stringUnit" : { "state" : "translated", "value" : "Каждый вопрос — луч света: спрашивайте ясно, чтобы получить точные ответы." } }
    } },
    "Tất cả" : { "localizations" : {
