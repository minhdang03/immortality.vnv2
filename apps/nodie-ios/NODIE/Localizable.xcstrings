    "Câu hỏi rõ được cộng đồng & chuyên gia trả lời nhanh hơn." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klare Fragen werden von Community & Experten schneller beantwortet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clear questions get faster answers from the community & experts."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las preguntas claras reciben respuestas más rápidas de la comunidad y los expertos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les questions claires reçoivent des réponses plus rapides de la communauté et des experts."
