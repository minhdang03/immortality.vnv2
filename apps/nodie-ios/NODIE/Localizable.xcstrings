    "Email này đã có tài khoản." : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "An account with this email already exists." } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "该邮箱已注册账号。" } },
