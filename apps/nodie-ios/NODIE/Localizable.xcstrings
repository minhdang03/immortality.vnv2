    "Chiếu câu hỏi / hình dung của bạn ra trước — rồi Bảng tin mới hút nội dung tương ứng về. Nạp vào mà không chiếu ra chỉ thành kho rác." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Strahle zuerst deine Frage oder Vorstellung aus — erst dann zieht die Feed passende Inhalte an. Aufnehmen ohne Ausstrahlen wird nur zur Müllhalde."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beam your question or vision out first — only then does the Feed attract matching content back. Taking in without beaming out just builds a junk pile."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Proyecta primero tu pregunta o tu visión: solo entonces el Feed atrae contenido afín. Absorber sin proyectar solo acumula basura."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diffusez d’abord votre question ou votre vision — ce n’est qu’ensuite que le Fil attire le contenu correspondant. Absorber sans diffuser ne crée qu’un dépotoir."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "まず問いやイメージを照らして出す — そうして初めてフィードが対応する内容を引き寄せます。出さずに取り込むだけでは、ただのゴミ置き場になります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "먼저 당신의 질문이나 상상을 비춰 내보내세요 — 그래야 피드가 그에 맞는 콘텐츠를 끌어옵니다. 내보내지 않고 담기만 하면 잡동사니 창고가 될 뿐입니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сначала осветите свой вопрос или образ — только тогда Лента притянет соответствующее. Поглощать, не излучая, — значит копить хлам."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
