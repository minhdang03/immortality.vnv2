            "state": "translated",
            "value": "パスワードは6文字以上にしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "비밀번호는 6자 이상이어야 해요."
          }
        },
        "fr": {
