      "ru" : { "stringUnit" : { "state" : "translated", "value" : "Аккаунт с этой почтой уже существует." } }
    } },
    "Mật khẩu phải từ 6 ký tự trở lên." : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "Password must be at least 6 characters." } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "密码至少需要 6 个字符。" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "パスワードは6文字以上にしてください。" } },
      "ko" : { "stringUnit" : { "state" : "translated", "value" : "비밀번호는 6자 이상이어야 해요." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Le mot de passe doit contenir au moins 6 caractères." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Das Passwort muss mindestens 6 Zeichen haben." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "La contraseña debe tener al menos 6 caracteres." } },
      "ru" : { "stringUnit" : { "state" : "translated", "value" : "Пароль должен быть не короче 6 символов." } }
    } },
    "Thử lại sau ít phút giúp mình." : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "Please try again in a few minutes." } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "请过几分钟再试。" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "数分後にもう一度お試しください。" } },
      "ko" : { "stringUnit" : { "state" : "translated", "value" : "몇 분 뒤에 다시 시도해 주세요." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Réessayez dans quelques minutes." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Bitte versuche es in ein paar Minuten erneut." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Inténtalo de nuevo en unos minutos." } },
      "ru" : { "stringUnit" : { "state" : "translated", "value" : "Попробуйте снова через несколько минут." } }
    } },
    "Không kết nối được. Kiểm tra mạng giúp mình nhé." : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "Couldn't connect. Please check your network." } },
