    "Link đã hết hạn hoặc mở trên máy khác. Gửi lại giúp mình nhé.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The link has expired or was opened on another device. Please send it again."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Link ist abgelaufen oder wurde auf einem anderen Gerät geöffnet. Bitte sende ihn erneut."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El enlace caducó o se abrió en otro dispositivo. Vuelve a enviarlo, por favor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le lien a expiré ou a été ouvert sur un autre appareil. Merci de le renvoyer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リンクの有効期限が切れたか、別の端末で開かれました。もう一度送ってください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "링크가 만료되었거나 다른 기기에서 열렸습니다. 다시 보내주세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Срок действия ссылки истёк или её открыли на другом устройстве. Отправьте её ещё раз."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "链接已过期或在其他设备上打开。请重新发送。"
          }
        }
      }
    },
    "Quên mật khẩu?": {
