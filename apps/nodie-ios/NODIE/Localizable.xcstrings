      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieser Name erscheint bei all deinen Fragen und Antworten. Später im Profil änderbar."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This name appears with all your questions and answers. You can change it later in Profile."
