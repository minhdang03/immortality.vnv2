    "Mỗi câu hỏi là một lần chiếu sáng — hỏi rõ để thu về câu trả lời đúng." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jede Frage ist ein Lichtstrahl — frag klar, um die richtigen Antworten anzuziehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Every question is a beam of light — ask clearly to attract the right answers."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada pregunta es un rayo de luz: pregunta con claridad para atraer las respuestas correctas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque question est un rayon de lumière — posez-la clairement pour attirer les bonnes réponses."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "質問はひとつの光。はっきり尋ねるほど、正しい答えが集まります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "질문 하나하나가 빛이 됩니다 — 명확히 물을수록 정확한 답이 모여요."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Каждый вопрос — луч света: спрашивайте ясно, чтобы получить точные ответы."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每个问题都是一次照亮——问得清楚，才能收获对的答案。"
          }
        }
      }
    },
