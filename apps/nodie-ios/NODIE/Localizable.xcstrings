      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Bon retour" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Willkommen zurück" } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Bienvenido de nuevo" } },
      "ru" : { "stringUnit" : { "state" : "translated", "value" : "С возвращением" } }
    } },
    "Nơi bạn chia sẻ tri thức và cùng nhau đi sâu." : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "Where you share knowledge and go deeper together." } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "在这里分享知识，一起深入探索。" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "知を分かち合い、共に深めていく場所。" } },
      "ko" : { "stringUnit" : { "state" : "translated", "value" : "지식을 나누고 함께 깊이 파고드는 곳." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Là où l'on partage le savoir et approfondit ensemble." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Wo du Wissen teilst und gemeinsam tiefer gehst." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Donde compartes conocimiento y profundizas en comunidad." } },
      "ru" : { "stringUnit" : { "state" : "translated", "value" : "Здесь делятся знаниями и вместе идут вглубь." } }
    } },
    "Đăng nhập để tiếp tục hành trình." : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "Sign in to continue your journey." } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "登录以继续你的旅程。" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "サインインして旅を続けましょう。" } },
      "ko" : { "stringUnit" : { "state" : "translated", "value" : "로그인하고 여정을 이어가세요." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Connectez-vous pour poursuivre votre parcours." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Melde dich an, um deine Reise fortzusetzen." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Inicia sesión para continuar tu camino." } },
      "ru" : { "stringUnit" : { "state" : "translated", "value" : "Войдите, чтобы продолжить путь." } }
