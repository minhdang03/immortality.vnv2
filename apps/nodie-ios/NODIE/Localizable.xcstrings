    "Có thể nó đã bị xoá, hoặc thuộc về người bạn đã chặn.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It may have been deleted, or it belongs to someone you blocked."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "它可能已被删除，或属于你屏蔽的人。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "削除されたか、ブロック中のユーザーのものかもしれません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "삭제되었거나 차단한 사용자의 것일 수 있어요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Elle a peut-être été supprimée, ou appartient à quelqu'un que vous avez bloqué."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie wurde vielleicht gelöscht oder gehört jemandem, den du blockiert hast."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puede que se haya eliminado o que sea de alguien que bloqueaste."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Возможно, он удалён или принадлежит заблокированному пользователю."
          }
        }
      }
    },
