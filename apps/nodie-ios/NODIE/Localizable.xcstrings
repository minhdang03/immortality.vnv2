      "ko" : { "stringUnit" : { "state" : "translated", "value" : "연결할 수 없어요. 네트워크를 확인해 주세요." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Connexion impossible. Vérifiez votre réseau." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Keine Verbindung. Bitte prüfe dein Netzwerk." } },
