          }
        }
      }
    },
    "Thử lại sau ít phút giúp mình.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please try again in a few minutes."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请过几分钟再试。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "数分後にもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "몇 분 뒤에 다시 시도해 주세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réessayez dans quelques minutes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitte versuche es in ein paar Minuten erneut."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inténtalo de nuevo en unos minutos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Попробуйте снова через несколько минут."
          }
        }
      }
    },
    "Không kết nối được. Kiểm tra mạng giúp mình nhé.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't connect. Please check your network."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法连接，请检查网络。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続できません。ネットワークをご確認ください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "연결할 수 없어요. 네트워크를 확인해 주세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connexion impossible. Vérifiez votre réseau."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine Verbindung. Bitte prüfe dein Netzwerk."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo conectar. Revisa tu red."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нет соединения. Проверьте сеть."
          }
        }
      }
    },
    "Có lỗi xảy ra. Thử lại giúp mình nhé.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Something went wrong. Please try again."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "出了点问题，请重试。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エラーが発生しました。もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "문제가 발생했어요. 다시 시도해 주세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une erreur est survenue. Réessayez."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Etwas ist schiefgelaufen. Bitte erneut versuchen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Algo salió mal. Inténtalo de nuevo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Что-то пошло не так. Попробуйте ещё раз."
          }
        }
      }
    },
    "Chậm lại chút — chờ 2 giây giữa các tin nhé.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Slow down a bit — wait 2 seconds between messages."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "慢一点——两条消息之间请间隔 2 秒。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "少しゆっくり——メッセージの間隔を2秒あけてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "조금 천천히 — 메시지 사이에 2초만 기다려 주세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Doucement — attendez 2 secondes entre les messages."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Etwas langsamer — warte 2 Sekunden zwischen Nachrichten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Más despacio: espera 2 segundos entre mensajes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Помедленнее — подождите 2 секунды между сообщениями."
          }
        }
      }
    },
    "Bạn không có quyền thực hiện thao tác này.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You don't have permission to do this."
          }
        },
        "zh-Hans": {
