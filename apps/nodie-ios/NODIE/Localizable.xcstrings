    "Chưa lưu câu hỏi nào. Bấm ◍ ở một câu hỏi để đọc lại sau.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No saved questions. Tap ◍ on a question to read it later."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "还没有收藏的问题。在问题上点 ◍ 即可稍后再读。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存した質問はありません。質問の ◍ をタップすると後で読めます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장한 질문이 없어요. 질문에서 ◍를 누르면 나중에 다시 읽을 수 있어요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune question enregistrée. Touchez ◍ sur une question pour la relire plus tard."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine gespeicherten Fragen. Tippe bei einer Frage auf ◍, um sie später zu lesen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay preguntas guardadas. Toca ◍ en una pregunta para leerla luego."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нет сохранённых вопросов. Нажмите ◍ у вопроса, чтобы прочитать позже."
          }
        }
      }
    },
