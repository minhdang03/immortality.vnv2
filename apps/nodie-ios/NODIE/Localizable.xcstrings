    "Chưa có câu trả lời. Hãy là người soi sáng đầu tiên.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No answers yet. Be the first to shed light."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "还没有回答。来做第一个点亮的人吧。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まだ回答がありません。最初に光を灯しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아직 답변이 없어요. 첫 번째로 빛을 비춰 보세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas encore de réponse. Soyez le premier à éclairer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch keine Antworten. Bring als Erster Licht hinein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay respuestas. Sé el primero en dar luz."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ответов пока нет. Пролейте свет первым."
          }
        }
      }
    },
