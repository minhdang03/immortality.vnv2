    "Phiên đăng nhập đã hết. Đăng nhập lại giúp mình nhé.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Sitzung ist abgelaufen. Bitte melde dich erneut an."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your session has expired. Please sign in again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu sesión ha caducado. Vuelve a iniciar sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre session a expiré. Merci de vous reconnecter."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セッションが切れました。もう一度ログインしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "세션이 만료되었어요. 다시 로그인해 주세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сессия истекла. Пожалуйста, войдите снова."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录会话已过期，请重新登录。"
          }
        }
      }
    },
