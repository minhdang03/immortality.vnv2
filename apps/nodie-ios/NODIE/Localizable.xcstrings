    "Kiểm tra hộp thư" : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "Check your inbox" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "查看你的邮箱" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "メールをご確認ください" } },
      "ko" : { "stringUnit" : { "state" : "translated", "value" : "메일함을 확인하세요" } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Vérifiez votre boîte mail" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Prüfe dein Postfach" } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Revisa tu correo" } },
      "ru" : { "stringUnit" : { "state" : "translated", "value" : "Проверьте почту" } }
    } },
    "Mình vừa gửi link xác nhận tới\n" : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "We just sent a confirmation link to\n" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "确认链接已发送至\n" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "確認リンクを送信しました：\n" } },
      "ko" : { "stringUnit" : { "state" : "translated", "value" : "확인 링크를 보냈어요:\n" } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Nous venons d'envoyer un lien de confirmation à\n" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Wir haben einen Bestätigungslink gesendet an\n" } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Acabamos de enviar un enlace de confirmación a\n" } },
      "ru" : { "stringUnit" : { "state" : "translated", "value" : "Мы отправили ссылку для подтверждения на\n" } }
    } },
    "Bấm link trong email rồi quay lại đây đăng nhập." : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "Tap the link in the email, then come back here to sign in." } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "点击邮件中的链接，然后回来登录。" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "メール内のリンクを開いてから、ここに戻ってサインインしてください。" } },
      "ko" : { "stringUnit" : { "state" : "translated", "value" : "메일의 링크를 누른 뒤 여기로 돌아와 로그인하세요." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Cliquez sur le lien dans l'e-mail, puis revenez ici pour vous connecter." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Tippe auf den Link in der E-Mail und melde dich dann hier an." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Abre el enlace del correo y vuelve aquí para iniciar sesión." } },
      "ru" : { "stringUnit" : { "state" : "translated", "value" : "Перейдите по ссылке в письме и вернитесь сюда, чтобы войти." } }
    } },
    "Quay lại đăng nhập" : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "Back to sign in" } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "返回登录" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "サインインに戻る" } },
      "ko" : { "stringUnit" : { "state" : "translated", "value" : "로그인으로 돌아가기" } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "Retour à la connexion" } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Zurück zur Anmeldung" } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Volver a iniciar sesión" } },
      "ru" : { "stringUnit" : { "state" : "translated", "value" : "Назад ко входу" } }
    } },
    "Khi dùng NODIE, bạn đồng ý với Điều khoản sử dụng." : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "By using NODIE, you agree to the Terms of Use." } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "使用 NODIE 即表示你同意《使用条款》。" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "NODIE を利用すると、利用規約に同意したことになります。" } },
      "ko" : { "stringUnit" : { "state" : "translated", "value" : "NODIE를 사용하면 이용약관에 동의하는 것입니다." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "En utilisant NODIE, vous acceptez les Conditions d'utilisation." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "Mit der Nutzung von NODIE stimmst du den Nutzungsbedingungen zu." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Al usar NODIE, aceptas los Términos de uso." } },
      "ru" : { "stringUnit" : { "state" : "translated", "value" : "Используя NODIE, вы принимаете Условия использования." } }
    } },

    "Email hoặc mật khẩu không đúng." : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "Incorrect email or password." } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "邮箱或密码不正确。" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "メールアドレスまたはパスワードが正しくありません。" } },
      "ko" : { "stringUnit" : { "state" : "translated", "value" : "이메일 또는 비밀번호가 올바르지 않습니다." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "E-mail ou mot de passe incorrect." } },
      "de" : { "stringUnit" : { "state" : "translated", "value" : "E-Mail oder Passwort ist falsch." } },
      "es" : { "stringUnit" : { "state" : "translated", "value" : "Correo o contraseña incorrectos." } },
      "ru" : { "stringUnit" : { "state" : "translated", "value" : "Неверная почта или пароль." } }
    } },
    "Email chưa được xác nhận. Kiểm tra hộp thư giúp mình nhé." : { "localizations" : {
      "en" : { "stringUnit" : { "state" : "translated", "value" : "Email not confirmed yet. Please check your inbox." } },
      "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "邮箱尚未验证，请查看你的邮箱。" } },
      "ja" : { "stringUnit" : { "state" : "translated", "value" : "メールが未確認です。受信箱をご確認ください。" } },
      "ko" : { "stringUnit" : { "state" : "translated", "value" : "이메일이 아직 인증되지 않았어요. 메일함을 확인해 주세요." } },
      "fr" : { "stringUnit" : { "state" : "translated", "value" : "E-mail non confirmé. Vérifiez votre boîte mail." } },
