    "Chiếu câu hỏi / hình dung của bạn ra trước — rồi Bảng tin mới hút nội dung tương ứng về. Nạp vào mà không chiếu ra chỉ thành kho rác.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Beam your question or vision out first — only then does the Feed attract matching content back. Taking in without beaming out just builds a junk pile."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Strahle zuerst deine Frage oder Vorstellung aus — erst dann zieht die Feed passende Inhalte an. Aufnehmen ohne Ausstrahlen wird nur zur Müllhalde."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Proyecta primero tu pregunta o tu visión: solo entonces el Feed atrae contenido afín. Absorber sin proyectar solo acumula basura."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Diffusez d’abord votre question ou votre vision — ce n’est qu’ensuite que le Fil attire le contenu correspondant. Absorber sans diffuser ne crée qu’un dépotoir."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まず問いやイメージを照らして出す — そうして初めてフィードが対応する内容を引き寄せます。出さずに取り込むだけでは、ただのゴミ置き場になります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "먼저 당신의 질문이나 상상을 비춰 내보내세요 — 그래야 피드가 그에 맞는 콘텐츠를 끌어옵니다. 내보내지 않고 담기만 하면 잡동사니 창고가 될 뿐입니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сначала осветите свой вопрос или образ — только тогда Лента притянет соответствующее. Поглощать, не излучая, — значит копить хлам."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "先把你的问题或设想照亮出去 — 信息流才会把对应的内容吸引回来。只吸收不照亮，只会堆成一座垃圾场。"
          }
        }
      }
    },
    "Vd: Trí nhớ dài hạn được củng cố lúc ngủ như thế nào?": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "E.g. How is long-term memory consolidated during sleep?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Z. B.: Wie wird das Langzeitgedächtnis im Schlaf gefestigt?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ej.: ¿Cómo se consolida la memoria a largo plazo durante el sueño?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ex. : Comment la mémoire à long terme se consolide-t-elle pendant le sommeil ?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "例：長期記憶は睡眠中にどう定着するのか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "예: 장기 기억은 잠자는 동안 어떻게 굳어지나요?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Напр.: Как долговременная память закрепляется во сне?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "例：长期记忆在睡眠中是如何巩固的？"
          }
        }
      }
    },
    "✦ Chiếu sáng & hút nội dung về": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "✦ Beam out & attract content back"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "✦ Ausstrahlen & Inhalte anziehen"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "✦ Proyectar y atraer contenido"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "✦ Diffuser et attirer du contenu"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "✦ 照らして引き寄せる"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "✦ 비추고 끌어오기"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "✦ Осветить и притянуть"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "✦ 照亮并吸引内容"
          }
        }
      }
    },
    "chiếu sáng trước → hút vào sau.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "beam out first → attract in after."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "erst ausstrahlen → dann anziehen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "proyectar primero → atraer después."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "diffuser d’abord → attirer ensuite."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まず照らす → それから引き寄せる。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "먼저 비추기 → 그다음 끌어오기."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "сначала осветить → потом притянуть."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "先照亮 → 后吸引。"
          }
        }
      }
    },
