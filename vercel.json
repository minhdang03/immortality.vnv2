{
  "rewrites": [
    { "source": "/story/:slug*", "destination": "/api/og?p=/story/:slug*" },
    { "source": "/khaitri/:slug*", "destination": "/api/og?p=/khaitri/:slug*" },
    { "source": "/article/:slug*", "destination": "/api/og?p=/article/:slug*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
