{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @btd/web build",
  "outputDirectory": "apps/web/dist",
  "functions": {
    "api/og.js": { "includeFiles": "apps/web/dist/index.html" }
  },
  "rewrites": [
    { "source": "/story/:slug*", "destination": "/api/og?p=/story/:slug*" },
    { "source": "/khaitri/:slug*", "destination": "/api/og?p=/khaitri/:slug*" },
    { "source": "/article/:slug*", "destination": "/api/og?p=/article/:slug*" },
    { "source": "/articles/:slug([\\w-]+)", "destination": "/api/og?p=/articles/:slug" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
