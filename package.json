{
  "name": "@btd/monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev:web": "pnpm --filter @btd/web dev",
    "build:web": "pnpm --filter @btd/web build",
    "preview:web": "pnpm --filter @btd/web preview",
    "deploy": "firebase deploy --only hosting,functions",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions:ogRenderer"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-builder": ">=1.1.7"
    }
  }
}
