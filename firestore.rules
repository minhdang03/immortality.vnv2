// Firestore Security Rules — Bất Tử Đạo
//
// Canonical source of truth. Deploy via CLI:
//   firebase deploy --only firestore:rules
// (firebase.json declares `"firestore": { "rules": "firestore.rules" }`)
//
// Covers donations, donor PII, comments (article subcollection), newsletter,
// content collections, and admin role management.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // Helpers — role-based access via /admins/{uid}.role
    // ─────────────────────────────────────────────────────────────
    // Doc shape: { role: 'admin' | 'moderator', email?, grantedAt, grantedBy }
    // Backward-compat: doc with no `role` field is treated as admin (legacy grants).
    // To grant: create /admins/<uid> with desired role.
    // To revoke: delete the doc.
    function adminDoc() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
    }
    function isSignedInAdminDoc() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isAdmin() {
      return isSignedInAdminDoc() && adminDoc().role == 'admin';
    }
    function hasRole(r) {
      return isSignedInAdminDoc() && adminDoc().role == r;
    }
    // 'moderator' is the legacy name for 'mod-articles' — accept both for backward compat.
    // 'agent' is a shared goclaw identity that writes both articles + khaitri.
    function canWriteArticles() {
      return isAdmin() || hasRole('mod-articles') || hasRole('moderator') || hasRole('agent');
    }
    function canWriteKhaitri() {
      return isAdmin() || hasRole('mod-khaitri') || hasRole('agent');
    }

    // ─────────────────────────────────────────────────────────────
    // Donations (public-safe)
    //   Public can READ only approved entries.
    //   Public can CREATE pending submissions with validated fields.
    //   Only admin can UPDATE / DELETE.
    // ─────────────────────────────────────────────────────────────
    match /donations/{id} {
      allow read: if resource.data.status == 'approved' || isAdmin();

      allow create: if request.resource.data.status == 'pending'
                    && request.resource.data.amount is number
                    && request.resource.data.amount > 0
                    && request.resource.data.amount < 1000000000  // < 1B VND sanity cap
                    && request.resource.data.isAnonymous is bool
                    && request.resource.data.createdAt == request.time
                    && !('approvedAt' in request.resource.data)
                    && !('approvedBy' in request.resource.data)
                    && (
                      request.resource.data.displayName == ''
                      || (
                        request.resource.data.displayName is string
                        && request.resource.data.displayName.size() <= 100
                      )
                    )
                    && (
                      request.resource.data.message == null
                      || (
                        request.resource.data.message is string
                        && request.resource.data.message.size() <= 500
                      )
                    );

      // Admin can transition status / set approvedAt / add adminNote.
      // Append-only on financial fields — amount, createdAt, displayName, isAnonymous CANNOT change post-create.
      allow update: if isAdmin()
                    && request.resource.data.amount == resource.data.amount
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.displayName == resource.data.displayName
                    && request.resource.data.isAnonymous == resource.data.isAnonymous
                    && request.resource.data.message == resource.data.message;
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // Donation contacts (PRIVATE — admin-only read)
    //   Public can CREATE (paired with /donations/{id}).
    //   Only admin can READ / UPDATE / DELETE.
    //   Email & phone NEVER exposed to public clients.
    // ─────────────────────────────────────────────────────────────
    match /donation_contacts/{id} {
      allow read, update, delete: if isAdmin();

      allow create: if (
        request.resource.data.realName is string
        && request.resource.data.realName.size() >= 2
        && request.resource.data.realName.size() <= 100
      ) && (
        request.resource.data.email == null
        || (
          request.resource.data.email is string
          && request.resource.data.email.size() <= 120
          && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
        )
      ) && (
        request.resource.data.phone == null
        || (
          request.resource.data.phone is string
          && request.resource.data.phone.size() >= 8
          && request.resource.data.phone.size() <= 30
          && request.resource.data.phone.matches('^[+0-9\\s\\-()]+$')
        )
      );
    }

    // ─────────────────────────────────────────────────────────────
    // Existing public collections — adjust to match current rules
    // ─────────────────────────────────────────────────────────────
    // Per-collection writes scoped to specific roles. Each goclaw agent gets ONLY the role
    // matching the content it produces — minimal blast radius if an agent's creds leak.
    match /articles/{id} {
      // Drafts hidden from public — only published or admin can read.
      // Article docs without a `status` field are treated as published (legacy).
      allow read: if !('status' in resource.data)
                  || resource.data.status == 'published'
                  || canWriteArticles();
      allow write: if canWriteArticles();

      // Comments live as a subcollection at /articles/{id}/comments/{cid}
      match /comments/{cid} {
        allow read: if true;
        allow create: if request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 2000
                      && request.resource.data.name is string
                      && request.resource.data.name.size() <= 80
                      && request.resource.data.status == 'pending';
        allow update, delete: if canWriteArticles();
      }
    }
    // Legacy top-level comments path — kept for backwards compat with anything still writing here.
    match /comments/{id} { allow read: if true; allow create: if true; allow update, delete: if canWriteArticles(); }
    // Khai Trí — drafts hidden from public.
    match /khaitri/{id} {
      allow read: if !('status' in resource.data)
                  || resource.data.status == 'published'
                  || canWriteKhaitri();
      allow write: if canWriteKhaitri();
    }

    // Newsletter signups — public create (validated), admin read/manage
    match /newsletter_signups/{id} {
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() > 4
                    && request.resource.data.email.size() < 200
                    && request.resource.data.email.matches('.+@.+\\..+');
      allow read, update, delete: if isAdmin();
    }

    // All other content: admin only
    match /stories/{id}         { allow read: if true; allow write: if isAdmin(); }
    match /topics/{id}          { allow read: if true; allow write: if isAdmin(); }
    match /teachings/{id}       { allow read: if true; allow write: if isAdmin(); }
    match /practices/{id}       { allow read: if true; allow write: if isAdmin(); }
    match /translations/{lang}  { allow read: if true; allow write: if isAdmin(); }
    match /settings/{id}        { allow read: if true; allow write: if isAdmin(); }
    match /contacts/{id} {
      allow read, update, delete: if isAdmin();
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() >= 2
                    && request.resource.data.name.size() <= 100
                    && request.resource.data.email is string
                    && request.resource.data.email.size() >= 5
                    && request.resource.data.email.size() <= 200
                    && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
                    && request.resource.data.message is string
                    && request.resource.data.message.size() >= 5
                    && request.resource.data.message.size() <= 4000
                    && request.resource.data.status == 'new';
    }

    // /admins — read rules:
    //   • Self-read: any signed-in user reads their OWN doc (so useUserRole resolves
    //     even for non-admins / not-yet-granted users without permission errors).
    //   • Full list read: admin only.
    // Write rules: admin only. Self-protection on delete.
    match /admins/{uid} {
      allow get: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin() && request.auth.uid != uid;
    }

    // Agent audit log — read by admins, write only via admin SDK / service account.
    // Client SDK never writes here; agents call functions/scripts/log-agent-op.js.
    match /agent_log/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // btd_knowledge — Notion → Firestore sync mirror (1-way, server-only write).
    // Public read for published articles; write blocked on client (Worker uses service account).
    match /btd_knowledge/{docId} {
      allow read: if resource.data.published == true && resource.data.archivedAt == null;
      allow write: if false; // written only by btd-notion-sync Worker via service account
    }

    // btd_ai_flags — flagged AI responses for admin review queue.
    // Written by btd-notion-sync Worker (service account). Readable by admins only.
    match /btd_ai_flags/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // btd_ai_usage — per-request AI usage log for billing telemetry.
    // Written by btd-notion-sync Worker (service account). Readable by admins only.
    match /btd_ai_usage/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // _sync_logs — internal sync operation logs.
    // Admin read only; never client-writable.
    match /_sync_logs/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
