{
  "hosting": {
    "public": "apps/web/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/article/**",
        "function": "ogRenderer"
      },
      {
        "source": "/articles/**",
        "function": "ogRenderer"
      },
      {
        "source": "/topic/**",
        "function": "ogRenderer"
      },
      {
        "source": "/stories",
        "function": "ogRenderer"
      },
      {
        "source": "/khaitri/**",
        "function": "ogRenderer"
      },
      {
        "source": "/khaitri",
        "function": "ogRenderer"
      },
      {
        "source": "/about",
        "function": "ogRenderer"
      },
      {
        "source": "/practice",
        "function": "ogRenderer"
      },
      {
        "source": "/articles",
        "function": "ogRenderer"
      },
      {
        "source": "/contact",
        "function": "ogRenderer"
      },
      {
        "source": "/nang-luong",
        "function": "ogRenderer"
      },
      {
        "source": "/search",
        "function": "ogRenderer"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" },
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
          { "key": "Content-Security-Policy", "value": "default-src 'self' https://*.firebaseio.com https://*.firebaseapp.com https://*.googleapis.com https://*.cloudfunctions.net https://pub-*.r2.dev; script-src 'self' 'wasm-unsafe-eval' https://*.googleapis.com https://*.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https: data: blob:; connect-src 'self' https://*.firebaseio.com https://*.firebaseapp.com https://*.googleapis.com https://*.cloudfunctions.net https://*.r2.dev wss://*.firebaseio.com; frame-src 'self' https://*.firebaseapp.com; object-src 'none'; base-uri 'self'; form-action 'self'" }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "/sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
