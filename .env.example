# immortality-vn / Bất Tử Đạo — env template. Copy to .env (gitignored) and fill.

# --- Supabase (migration in progress) ---
# Client uses ANON key only. service_role NEVER goes here or in any client bundle —
# it lives only in the Worker secret (phase-05) and a local vault for `supabase db push`.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Firebase (still live in prod until phase-08 cutover) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=immortalityvn.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=immortalityvn
VITE_FIREBASE_STORAGE_BUCKET=immortalityvn.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=204809901558
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
